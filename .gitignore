package-lock.json
yarn.lock

# ============================================
# LOGS Y TEMPORALES
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
tmp/
temp/

# ============================================
# CARPETA DE SUBIDAS (No usada en Vercel)
# ============================================
uploads/

# ============================================
# RESPALDOS DE BASE DE DATOS
# Contienen datos reales (emails, pedidos, etc.)
# NUNCA subir al repositorio
# ============================================
backups/

# ============================================
# DOCUMENTACIÓN INTERNA (Solo desarrollo local)
# ============================================
docs/
MAPA_BACKEND.md

# ============================================
# ARCHIVOS ARCHIVADOS (Legacy code)
# ============================================
archive/

# ============================================
# SCRIPTS DE UTILIDAD LOCAL (Testing/Debug)
# ============================================
# Scripts de mantenimiento que no forman parte del proyecto
# Útiles localmente pero no necesarios en el repositorio
src/scripts/

