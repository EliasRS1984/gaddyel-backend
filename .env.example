# ============================================
# GADDYEL E-COMMERCE BACKEND
# Archivo de configuración (.env)
# ============================================

# NODE ENVIRONMENT
NODE_ENV=development

# PUERTO DEL SERVIDOR
PORT=5000

# ============================================
# DATABASE (MongoDB)
# ============================================
MONGODB_URI=mongodb://localhost:27017/gaddyel-ecommerce
# Alternativa: MongoDB Atlas
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/gaddyel-ecommerce?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://username:password@cluster-name.mongodb.net/database-name?appName=app-name

# ============================================
# MERCADO PAGO
# ============================================
# Obtener en: https://www.mercadopago.com.ar/developers/es/reference
MERCADOPAGO_ACCESS_TOKEN=APP_USR-1234567890-xxxxxxxxxxxxxxxxxxxx
MERCADOPAGO_WEBHOOK_SECRET=tu_webhook_secret_de_mercadopago

# ============================================
# URLs
# ============================================
# URL del backend (para webhooks)
API_URL=http://localhost:5000

# URL del frontend (para redirecciones post-pago)
FRONTEND_URL=http://localhost:5173

# Origins permitidos para CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://gaddyel.com

# ============================================
# AUTENTICACIÓN (JWT)
# ============================================
JWT_SECRET=tu_jwt_secret_muy_largo_y_seguro
REFRESH_TOKEN_EXP_DAYS=30

# ============================================
# SEGURIDAD
# ============================================
# Secret para firmar cookies
SESSION_SECRET=your_session_secret_key

# Hash salt para passwords
BCRYPT_ROUNDS=10

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# CLOUDINARY (Almacenamiento de imágenes)
# ============================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================
# EMAIL (Opcional - para notificaciones)
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu_email@gmail.com
# SMTP_PASS=tu_contraseña_de_aplicación
# EMAIL_FROM=noreply@gaddyel.com

# ============================================
# STRIPE (Opcional - alternativa a Mercado Pago)
# ============================================
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# ============================================
# AWS (Opcional - para almacenamiento de imágenes)
# ============================================
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=gaddyel-images

# ============================================
# LOGGING & MONITORING
# ============================================
LOG_LEVEL=info
# Sentry (error tracking - opcional)
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ============================================
# FUNCIONALIDADES
# ============================================
# Habilitar sandbox de Mercado Pago
MERCADOPAGO_SANDBOX=true

# Máximos intentos de pago
MAX_PAYMENT_RETRIES=3

# Tiempo de expiración de preferencias (minutos)
PREFERENCE_EXPIRATION_MINUTES=60

# ============================================
# ADMIN
# ============================================
# Email del administrador
ADMIN_EMAIL=admin@gaddyel.com

# Teléfono del soporte
SUPPORT_PHONE=+54 9 11 2345-6789

# ============================================
# DESARROLLO SOLO
# ============================================
# Debug mode
DEBUG=false

# Mock de Mercado Pago (para desarrollo sin conectar a API real)
MERCADOPAGO_MOCK=false
